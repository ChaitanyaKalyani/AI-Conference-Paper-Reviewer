# OpenRouter API Key (required)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key

# LLM Configuration
LLM_MODEL=openai/gpt-oss-20b:free
LLM_TEMPERATURE=0
LLM_TOP_P=0.1

# Application Settings
MAX_PDF_PAGES=100
MAX_TEXT_LENGTH=50000
MAX_RETRIES=3
TIMEOUT_SECONDS=30

# Logging
LOG_LEVEL=INFO
